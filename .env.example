NEXT_PUBLIC_SUPABASE_URL=https://kqrarrrojdtxijkhejhg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
GOOGLE_PLACES_API_KEY=

# Cal.com — CTA "Réserver une démo" (BookDemoButton)
# Fallbacks: anthony-malartre / 15min
NEXT_PUBLIC_CAL_USERNAME=anthony-malartre
NEXT_PUBLIC_CAL_EVENT_TYPE=15min

# ─── Tracking publicitaire (gated consentement marketing) ───────────────
# Tous OPTIONNELS : sans valeur, les pixels ne se chargent pas (no-op).
# À renseigner sur Vercel (Production) quand les comptes pub sont prêts.
NEXT_PUBLIC_GA_ID=                  # GA4 Measurement ID, ex. G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=          # Meta (Facebook) Pixel ID, numérique
# LinkedIn : Partner ID (chargement du tag) + IDs de conversion (events)
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
NEXT_PUBLIC_LINKEDIN_CONVERSION_SIGNUP=
NEXT_PUBLIC_LINKEDIN_CONVERSION_PURCHASE=

# ─── Stripe — coupons promo auto-appliqués au checkout ──────────────────
# MAX99 : MAX mensuel → 99 €/mois les 3 premiers mois. Défaut codé = 0k6rxEgs.
# Override uniquement si tu recrées le coupon. (Business = coupon legacy.)
STRIPE_MAX_PROMO_COUPON_ID=
STRIPE_BUSINESS_PROMO_COUPON_ID=
